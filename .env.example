# LazyLabel Web — backend environment variables
# Copy this file to .env and fill in the values for your setup.

# ---------------------------------------------------------------------------
# SAM2 model (required)
# ---------------------------------------------------------------------------
# Absolute path to the SAM2 checkpoint (.pt) file.
LAZYLABEL_WEB_SAM2_CHECKPOINT=/path/to/sam2.1_hiera_large.pt

# ---------------------------------------------------------------------------
# SAM2 config (optional)
# ---------------------------------------------------------------------------
# Either a bundled SAM2 config name or an absolute path to a custom YAML.
# Default: configs/sam2.1/sam2.1_hiera_large.yaml  (bundled with SAM2)
# LAZYLABEL_WEB_SAM2_CONFIG=configs/sam2.1/sam2.1_hiera_large.yaml

# ---------------------------------------------------------------------------
# Inference device (optional)
# ---------------------------------------------------------------------------
# Choices: cuda (default), cpu, mps
# LAZYLABEL_WEB_DEVICE=cuda

# ---------------------------------------------------------------------------
# Storage / project data directory (optional)
# ---------------------------------------------------------------------------
# Root directory for all project data (frames, masks, metadata).
# Default: platform-specific (~/.local/share/lazylabel-web on Linux,
#          ~/Library/Application Support/lazylabel-web on macOS,
#          %APPDATA%\lazylabel-web on Windows)
# LAZYLABEL_WEB_DATA_DIR=/path/to/data
