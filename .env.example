# LazyLabel Web — backend environment variables
# Copy this file to .env and fill in the values for your setup.
# The backend reads these at startup; none are required if the defaults suit you.

# ---------------------------------------------------------------------------
# Model directory (SAM2 config + weights)
# ---------------------------------------------------------------------------
# The single directory where the backend looks for both the SAM2 config YAML
# and the weights file by default. Place both files here and you're done.
# Default: <DATA_DIR>/models  (see DATA_DIR below)
# LAZYLABEL_WEB_MODELS_DIR=/path/to/models

# Path to the SAM2 config YAML.
# Default: <MODELS_DIR>/sam2.1_hiera_large.yaml
# LAZYLABEL_WEB_SAM2_CONFIG=/path/to/models/sam2.1_hiera_large.yaml

# Path to the SAM2 checkpoint (.pt) file.
# Default: <MODELS_DIR>/sam2.1_hiera_large.pt
# LAZYLABEL_WEB_SAM2_WEIGHTS=/path/to/models/sam2.1_hiera_large.pt

# ---------------------------------------------------------------------------
# Inference device
# ---------------------------------------------------------------------------
# Choices: cuda (default), cpu, mps
# LAZYLABEL_WEB_DEVICE=cuda

# ---------------------------------------------------------------------------
# Storage / project data directory
# ---------------------------------------------------------------------------
# Root directory for all project data (frames, masks, metadata).
# Default: platform-specific (~/.local/share/lazylabel-web on Linux,
#          ~/Library/Application Support/lazylabel-web on macOS,
#          %APPDATA%\lazylabel-web on Windows)
# LAZYLABEL_WEB_DATA_DIR=/path/to/data
